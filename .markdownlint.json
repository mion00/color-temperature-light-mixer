{
  "default": true,
  "MD004": false,
  "MD013": false,
  "MD028": false,
  "MD036": false,
  "MD041": false,
  "no-trailing-punctuation": false,
  "no-inline-html": {
    "allowed_elements": [
      "a",
      "abbr",
      "bdo",
      "br",
      "caption",
      "cite",
      "dd",
      "del",
      "details",
      "dfn",
      "div",
      "dl",
      "dt",
      "em",
      "figcaption",
      "figure",
      "img",
      "ins",
      "kbd",
      "mark",
      "picture",
      "q",
      "rp",
      "rt",
      "ruby",
      "samp",
      "small",
      "source",
      "span",
      "strong",
      "sub",
      "summary",
      "sup",
      "table",
      "tbody",
      "td",
      "tfoot",
      "th",
      "thead",
      "time",
      "tr",
      "u",
      "var",
      "wbr"
    ]
  },
  "code-block-style": {
    "style": "fenced"
  },
  "emphasis-style": {
    "style": "underscore"
  },
  "strong-style": {
    "style": "asterisk"
  }
}
